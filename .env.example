# Mot de passe d'accès au cockpit de prospection (/cockpit).
# À définir aussi sur Vercel : Settings → Environment Variables.
# Tant qu'il n'est pas défini, personne ne peut se connecter.
COCKPIT_PASSWORD=change-moi

# ID du formulaire Formspree pour le formulaire de contact du site public.
NEXT_PUBLIC_FORMSPREE_ID=
